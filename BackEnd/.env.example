WEB_DB_HOST=localhost
WEB_DB_PORT=3306
WEB_DB_NAME=zentrix_web
WEB_DB_USER=root
WEB_DB_PASSWORD=sua_senha_aqui

# Opcional. Ajuste conforme o tamanho do servidor e numero de lojas/PDVs.
WEB_DB_MAX_POOL_SIZE=10
WEB_DB_MIN_IDLE=1
WEB_DB_CONNECTION_TIMEOUT_MS=5000
WEB_DB_VALIDATION_TIMEOUT_MS=3000
WEB_DB_IDLE_TIMEOUT_MS=300000
WEB_DB_MAX_LIFETIME_MS=1800000

# Obrigatorio. O PDV deve enviar este valor no header X-Zentrix-Sync-Key.
ZENTRIX_SYNC_KEY=troque-por-uma-chave-grande-e-secreta
# Exige sourceId/deviceId no pull/ack quando a loja ja possui device cadastrado.
ZENTRIX_SYNC_REQUIRE_KNOWN_DEVICE_SCOPE=true

# Obrigatorio para rotas de ativacao remota do PDV.
# Envie no header X-Zentrix-Setup-Key. Nao use o mesmo valor da chave de sync.
ZENTRIX_SETUP_KEY=troque-por-outra-chave-grande-e-secreta

# Opcional. Sessao do painel em minutos.
ZENTRIX_AUTH_TOKEN_TTL_MINUTES=480
# Cookie HttpOnly de sessao. Em producao HTTPS/Nginx, use secure=true.
ZENTRIX_AUTH_COOKIE_NAME=ZENTRIX_AUTH
ZENTRIX_AUTH_COOKIE_SECURE=false
ZENTRIX_AUTH_COOKIE_SAME_SITE=Lax
ZENTRIX_AUTH_COOKIE_MAX_AGE_MINUTES=480

# Opcional. URL publica usada em servidor Ubuntu/rede local para documentacao e scripts.
# Exemplo: https://pdv.zentrixsystems.com.br/
ZENTRIX_PUBLIC_URL=

# Opcional. Limites por IP para reduzir abuso e brute force.
ZENTRIX_RATE_LIMIT_ENABLED=true
ZENTRIX_RATE_LIMIT_DEFAULT_LIMIT=240
ZENTRIX_RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
ZENTRIX_RATE_LIMIT_AUTH_LIMIT=30
ZENTRIX_RATE_LIMIT_AUTH_WINDOW_SECONDS=300
ZENTRIX_RATE_LIMIT_SYNC_LIMIT=120
ZENTRIX_RATE_LIMIT_SYNC_WINDOW_SECONDS=60
# Use true somente quando o backend estiver protegido atras do Nginx/proxy.
ZENTRIX_RATE_LIMIT_TRUST_PROXY_HEADERS=false

# Opcional. Use true apenas em ambiente local/diagnostico.
ZENTRIX_HEALTH_DETAILS=false

# Opcional. Origens autorizadas para abrir o painel web fora do localhost.
# Exemplo producao: https://pdv.zentrixsystems.com.br
ZENTRIX_CORS_ALLOWED_ORIGINS=
ZENTRIX_CORS_ALLOWED_ORIGIN_PATTERNS=
# Use true apenas em teste local com arquivo file://. Em producao, mantenha false.
ZENTRIX_CORS_ALLOW_NULL_ORIGIN=false

# Opcional. Fontes extras permitidas no connect-src da Content-Security-Policy.
# Normalmente deixe vazio; use apenas se a API ficar em outro host/porta.
ZENTRIX_CSP_CONNECT_SRC=
